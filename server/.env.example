GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
PORT=3001

# Email (Gmail SMTP — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# App URL (used in email links)
APP_URL=http://localhost:5173

# QuickBooks Online OAuth2
# Create an app at https://developer.intuit.com
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3001/api/quickbooks/callback
QB_ENVIRONMENT=sandbox
